# Copy this file to .env and fill in all values before running docker-compose.
# Never commit .env to version control.

# Neo4j credentials — required. No default; must be set explicitly.
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Neo4j connection URI (optional — defaults to bolt://neo4j:7687 in docker-compose)
# NEO4J_URI=bolt://neo4j:7687

# Shared secret for meta-agent authentication — required. No default.
META_SHARED_SECRET=
